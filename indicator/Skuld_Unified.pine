float inAppFar     = input.float(1.5, "Window far edge (× target)", minval = 0.6, step = 0.1, group = GA)
float inAppPos     = input.float(0.55, "With-move close position ≥", minval = 0.5, maxval = 1, step = 0.05, group = GA)
