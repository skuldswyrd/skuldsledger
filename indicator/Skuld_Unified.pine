bool  enAPP        = input.bool(true, "Enable APP play (toward)", group = GA, tooltip = "Ride INTO a powerful level once inside the approach window. Target lands at/just in front of the level — never hold through it; the reaction there is a new decision.")
int   inAppRank    = input.int(8, "Min rank of destination level", minval = 4, maxval = 30, group = GA)
