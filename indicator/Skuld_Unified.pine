bool inHardCap = input.bool(false, "Hard-stop signals at max", group = GT, tooltip = "ON = indicator stops firing after max (plan: 'indicator stops signaling after 3 fires'). OFF = counter keeps counting, signals keep coming — display-only discipline.")
