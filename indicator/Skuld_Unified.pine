bool showDash = input.bool(true, "Status panel", group = GD)

color colS5   = input.color(#ffd54f, "★★★★★ cluster", group = GC)
color colS4   = input.color(#ff9800, "★★★★ cluster", group = GC)
color colS3   = input.color(#2962ff, "★★★ cluster", group = GC)
color colS2   = input.color(#787b86, "★★ cluster", group = GC)
color colS1   = input.color(#4c5158, "★ cluster", group = GC)
color colVpOut = input.color(#3a3e47, "VP rows outside VA", group = GC)
color colVpVa  = input.color(#2962ff, "VP rows inside VA", group = GC)
color colVpPoc = input.color(#ff9800, "VP POC row / dev POC", group = GC)
