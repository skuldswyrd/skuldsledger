bool  enMR     = input.bool(true, "Enable MR play", group = GR)
float inWick   = input.float(0.55, "Rejection: close position ≥ (0.5–1)", minval = 0.5, maxval = 1, step = 0.05, group = GR, tooltip = "Long: close must sit in top fraction of bar range. Short mirrored.")
